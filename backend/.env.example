# Copy this file to .env and fill in your real key
# Command: cp .env.example .env

# Anthropic API key (get one at https://console.anthropic.com)
ANTHROPIC_API_KEY=

# Model to use for most tasks (fast + cheap, good for RAG/extraction)
ANTHROPIC_MODEL=claude-sonnet-4-6

# Optional: model for harder reasoning tasks (RCA, pattern mining). Defaults to same as above if not set.
ANTHROPIC_REASONING_MODEL=claude-sonnet-4-6

# Server port
PORT=8000

# Twilio WhatsApp integration (OPTIONAL - see TWILIO_SETUP.md)
# Leave blank to use the simulated-only WhatsApp UI (no real messages sent/received).
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886
